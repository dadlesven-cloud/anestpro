# ── Telegram ──────────────────────────────────────────────────────────────
# Получить токен у @BotFather в Telegram
TG_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID чата/канала куда слать заявки.
# Личный chat_id: написать /start боту @userinfobot
# Для группы/канала: добавить бота и написать /id
TG_CHAT_ID=-1001234567890

# ── Google Sheets ──────────────────────────────────────────────────────────
# URL из Apps Script: Развернуть → Веб-приложение → скопировать ссылку
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycb.../exec

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3001
